---
import Layout from '../layouts/Layout.astro';

const releases = [
  {
    version: '1.0.3',
    date: '2026-04-09',
    changes: [
      'Restored bulk uninstall and per-addon trash button on installed page',
      'Restored improved plain-text dependency extraction from addon descriptions',
      'New app icon and favicon',
      'Fixed CI branch refs',
    ]
  },
  {
    version: '1.0.2',
    date: '2026-04-06',
    changes: [
      'Improved addon version detection',
      'Fixed addon update issues',
      'UI polish',
    ]
  },
  {
    version: '1.0.1',
    date: '2026-03-15',
    changes: [
      'Added bulk uninstall on installed page',
      'Improved plain-text dependency extraction',
      'Better search performance',
      'Network timeout error handling',
    ]
  },
  {
    version: '1.0.0',
    date: '2026-02-20',
    changes: [
      'Initial release',
      'One-click install and uninstall',
      'Automatic dependency detection',
      'Bulk updates',
      'Windows, Linux, macOS',
    ]
  },
];

const latestDate = releases[0].date;
---

<Layout
  title="Changelog — Scribe ESO Addon Manager"
  description="What changed in each version of Scribe."
  breadcrumb={[{ label: 'Changelog', href: '/changelog' }]}
  extraStructuredData={[{
    "@type": "WebPage",
    "name": "Scribe Changelog",
    "description": "What changed in each version of Scribe.",
    "datePublished": "2026-02-20",
    "dateModified": latestDate
  }]}
>
  <div class="page">
    <div class="page__inner">
      <h1>Changelog</h1>
      <p class="subtitle">What's new, what's fixed.</p>

      {releases.map(release => (
        <div class="release">
          <div class="release__header">
            <h2>v{release.version}</h2>
            <time class="release__date" datetime={release.date}>
              {new Date(release.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
          </div>
          <ul>
            {release.changes.map(change => (
              <li>{change}</li>
            ))}
          </ul>
        </div>
      ))}

      <p>Full history at <a href="https://github.com/KelpHect/Scribe/releases" target="_blank" rel="noopener noreferrer">GitHub Releases</a>.</p>
    </div>
  </div>
</Layout>
